# Database connection URL (required)
# Examples:
# - SQLite:  sqlite:///example.db
# - Postgres: postgresql+psycopg://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite:///example.db

# LLM provider selection: openai | huggingface
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0

# Required when MODEL_PROVIDER=openai
OPENAI_API_KEY=

# Required when MODEL_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=
# Optional override (OpenAI-compatible HF endpoint)
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Query guardrails
MAX_ROWS=100
# TABLE_ALLOWLIST=users,orders,transactions
